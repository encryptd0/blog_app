<div class="author">
  <h1 class="author_heading">Hi, I am Ricky.</h1>
  <p class="author__body">Web dev and Sys Admin</p>
  <img src="/img/hero-image.webp" alt="" class="hero-img" />

  <section class="articles">
    <h2 class="articles__heading">What im working on</h2>

    <ul class="article-ul">
      <!-- we can use a foreach loop in ejs to loop through the post dummy data in the db  -->
      <% data.forEach(post => { %>
      <li>
        <a href="<%= post._id  %>">
          <span><%= post.title  %></span>
          <span class="article-list__date"><%= post.createdAt.toDateString() %></span>
        </a>
      </li>
      <% }) %>
    </ul>

    <% if (nextPage !== null) { %>
      <a href="/?page=<%= nextPage %>" class="pagination">&lt; View Older Posts</a>
    <% } %>

  </section>
</div>
